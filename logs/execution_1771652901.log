      brief += `- Entries: ${session.entryCount}\n`;
      brief += `- Themes: ${session.themes.join(', ') || 'none detected'}\n`;
      brief += `- Sample: ${session.sample.slice(0, 150)}...\n\n`;
    }
    
    return brief;
  }
